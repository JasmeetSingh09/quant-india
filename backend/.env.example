# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env — it is gitignored.

# NewsAPI — get a free key at https://newsapi.org/register (~32 chars)
NEWS_API_KEY=your_newsapi_key_here

# Gmail alerts (optional — only needed for email alerts)
# GMAIL_APP_PASSWORD: generate at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
GMAIL_RECEIVER=where_alerts_go@gmail.com

# URLs — local dev defaults shown; change for production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
